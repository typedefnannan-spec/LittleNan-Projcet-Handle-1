<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.WM.dao.ShoppingCartDao">

    <insert id="insert">
        insert into shopping_cart(name,image,user_id,dish_id,setmeal_id,dish_flavor,number,amount,create_time)
        values(#{name},#{image},#{userId},#{dishId},#{setmealId},#{dishFlavor},#{number},#{amount},now())
    </insert>

    <select id="select" resultType="com.WM.entity.ShoppingCart">
        select * from shopping_cart
        <where>
            <if test="userId!=null">and user_id=#{userId}</if>
            <if test="dishId!=null">and dish_id=#{dishId}</if>
            <if test="setmealId!=null">and setmeal_id=#{setmealId}</if>
            <if test="dishFlavor!=null">and dish_flavor=#{dishFlavor}</if>
        </where>
    </select>

    <update id="update">
        update shopping_cart
        <set>
            <if test="name!=null">name=#{name},</if>
            <if test="image!=null">image=#{image},</if>
            <if test="userId!=null">user_id=#{userId},</if>
            <if test="dishId!=null">dish_id=#{dishId},</if>
            <if test="setmealId!=null">setmeal_id=#{setmealId},</if>
            <if test="dishFlavor!=null">dish_flavor=#{dish_flavor},</if>
            <if test="number!=null">number=#{number},</if>
            <if test="amount!=null">amount=#{amount},</if>
        </set>
        where id=#{id}
    </update>

    <delete id="deleteById">
        delete from shopping_cart where id=#{id}
    </delete>


    <delete id="deleteAll">
        delete from shopping_cart where user_id=#{userId}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.WM.dao.SetmealDishDao">
    
    <insert id="insert">
        insert into setmeal_dish(setmeal_id,dish_id,name,price,copies) 
        values 
        <foreach collection="dishes"  item="dish" separator=",">
            (#{Id},#{dish.dishId},#{dish.name},#{dish.price},#{dish.copies})
        </foreach>
    </insert>

    <select id="selectBydishId" resultType="Boolean">
        select count(*) from setmeal_dish
        where dish_id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <delete id="delete">
        delete from setmeal_dish
        where setmeal_id in
        <foreach collection="ids" item="id" open="("  separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
